# ============================================================
# 数据库配置
# ============================================================
DATABASE_URL=postgresql+asyncpg://dev:dev@db:5432/bookkeeping_dev
POSTGRES_DB=bookkeeping_dev
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# ============================================================
# 安全配置
# ============================================================
# 生产环境请使用强随机密钥: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-secret-key

# ============================================================
# 邮件服务配置（开发环境使用 mailpit）
# ============================================================
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# 对象存储配置
# STORAGE_BACKEND: local | s3
# ============================================================
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage/images
S3_ENDPOINT_URL=http://objstore:9000
S3_BUCKET_NAME=bookkeeping-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ============================================================
# MinIO 配置（生产对象存储）
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================================
# 应用配置
# ============================================================
APP_ENV=development
# ALLOWED_ORIGINS 多个来源用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8025

# ============================================================
# Cloudflare Tunnel（生产环境 token 方式）
# ============================================================
# 在 Cloudflare Zero Trust 创建 Tunnel 后，复制 Docker/命令行安装里提供的 token。
# 生产 .env.prod 中必须填写；不要提交真实 token。
TUNNEL_TOKEN=
